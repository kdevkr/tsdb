# kdb+ Tick 아키텍처 환경 설정
# -------------------------------------------

# 포트 설정
TP_PORT=5010
RDB_PORT=5011
HDB_PORT=5012
RTS_PORT=5013
GW_PORT=5014
WDB_PORT=5015

# 프로세스 연결 주소
TP_ADDR=:5010
RTS_ADDR=:5013
HDB_ADDR=:5012

# 데이터베이스 설정
HDB_DIR=.
TP_RETENTION=7

# 시스템 제한 및 인터벌
QUERY_TIMEOUT=30
WDB_FLUSH_INTERVAL=60000
